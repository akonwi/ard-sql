use go:regexp
use go:github.com/akonwi/ard-sql/ffi
use go:strings

// A wrapper over Go's database/sql, replacing the removed `ard/sql` stdlib module. Backed by pure-Go drivers so the compiled binary needs no
// CGO:
//
//   - "pgx"    (github.com/jackc/pgx/v5/stdlib)  for Postgres
//   - "sqlite" (modernc.org/sqlite)              for SQLite
//   - "mysql"  (github.com/go-sql-driver/mysql)  for MySQL
//
// Public surface intentionally mirrors the old ard/sql API so callers don't
// change: Database.query("...").all(["name": val]) etc. Rows come back as
// [Str: Any] maps, suitable for decoding into typed values.

// ─── Driver detection ────────────────────────────────────────────────────

fn detect_driver(url: Str) Str {
  let u = strings::TrimSpace(url)
  match {
    strings::HasPrefix(u, "postgres://") or strings::HasPrefix(u, "postgresql://") => "pgx",
    strings::Contains(u, "@tcp(") or strings::Contains(u, "@unix(") => "mysql",
    _ => "sqlite",
  }
}

// ─── Named-parameter rewriter ────────────────────────────────────────────
//
// SQL is written with @name placeholders. We rewrite:
//   pgx           -> $1, $2, ...        (positional numbered)
//   sqlite, mysql -> ?                  (positional unnumbered)
// Each occurrence of a @name (including repeats) becomes one placeholder
// and one value is looked up from the args map by that name.

// Named-param regex: @ followed by an identifier. Kept simple to match the
// only shapes migr actually emits (@name, @batch, etc.).
let param_regex: mut regexp::Regexp = regexp::MustCompile("@([A-Za-z_][A-Za-z0-9_]*)")

fn extract_params(sql: Str) [Str] {
  mut params: [Str] = []
  let matches = param_regex.FindAllStringSubmatch(sql, -1)
  for match_group in matches {
    let name = match_group.at(1).expect("regex has one capture group")
    params.push(name)
  }
  params
}

struct PreparedQuery {
  string: Str,
  values: [Any],
}

fn prepare(sql: Str, driver: Str, params: [Str], args: [Str: Any]) PreparedQuery!Str {
  mut query_str = sql
  mut values: [Any] = []
  mut position = 1

  for param in params {
    let placeholder = match driver {
      "pgx" => "${position}",
      _ => "?",
    }
    // Replace only the first remaining occurrence so duplicate params get
    // distinct positional bindings under pgx.
    query_str = strings::Replace(query_str, "@{param}", placeholder, 1)

    let value = try args.get(param) -> _ { Result::err("Missing parameter: {param}") }
    values.push(value)
    position =+ 1
  }

  Result::ok(PreparedQuery{string: query_str, values: values})
}

// ─── Handles ─────────────────────────────────────────────────────────────

struct Database {
  handle: mut ffi::DB,
  driver: Str,
  url: Str,
}

struct Transaction {
  handle: mut ffi::Tx,
  driver: Str,
}

// A Query is bound to either a Database or a Transaction (exactly one of
// db / tx is set). Ard doesn't have sum types across FFI cleanly here, so
// two nullable fields with a runtime invariant is the simplest thing.
struct Query {
  string: Str,
  params: [Str],
  driver: Str,
  db: (mut ffi::DB)?,
  tx: (mut ffi::Tx)?,
}

// ─── Open / close / begin ────────────────────────────────────────────────

fn open(url: Str) Database!Str {
  let driver = detect_driver(url)
  let handle = try ffi::Open(driver, url)
  Result::ok(
    Database{
      handle: handle,
      driver: driver,
      url: url,
    },
  )
}

impl Database {
  fn close() Void!Str {
    ffi::Close(self.handle)
  }

  fn exec(stmt: Str) Void!Str {
    mut empty: [Any] = []
    ffi::ExecDB(self.handle, stmt, empty)
  }

  fn query(stmt: Str) Query {
    Query{
      string: stmt,
      params: extract_params(stmt),
      driver: self.driver,
      db: Maybe::new(self.handle),
      tx: Maybe::new<mut ffi::Tx>(),
    }
  }

  fn begin() Transaction!Str {
    let handle = try ffi::Begin(self.handle)
    Result::ok(Transaction{handle: handle, driver: self.driver})
  }
}

impl Transaction {
  fn exec(stmt: Str) Void!Str {
    mut empty: [Any] = []
    ffi::ExecTx(self.handle, stmt, empty)
  }

  fn query(stmt: Str) Query {
    Query{
      string: stmt,
      params: extract_params(stmt),
      driver: self.driver,
      db: Maybe::new<mut ffi::DB>(),
      tx: Maybe::new(self.handle),
    }
  }

  fn commit() Void!Str {
    ffi::Commit(self.handle)
  }

  fn rollback() Void!Str {
    ffi::Rollback(self.handle)
  }
}

// ─── Query execution ─────────────────────────────────────────────────────

impl Query {
  fn run(args: [Str: Any]) Void!Str {
    let prepared = try prepare(self.string, self.driver, self.params, args)
    mut values = prepared.values
    match self.db {
      db => ffi::ExecDB(db, prepared.string, values),
      _ => {
        match self.tx {
          tx => ffi::ExecTx(tx, prepared.string, values),
          _ => Result::err("Query bound to neither a Database nor a Transaction"),
        }
      },
    }
  }

  fn all(args: [Str: Any]) [Any]!Str {
    let prepared = try prepare(self.string, self.driver, self.params, args)
    mut values = prepared.values
    match self.db {
      db => ffi::QueryDB(db, prepared.string, values),
      _ => {
        match self.tx {
          tx => ffi::QueryTx(tx, prepared.string, values),
          _ => Result::err("Query bound to neither a Database nor a Transaction"),
        }
      },
    }
  }

  fn first(args: [Str: Any]) Maybe<Any>!Str {
    let rows = try self.all(args)
    match rows.size() {
      0 => Result::ok(Maybe::new<Any>()),
      _ => Result::ok(Maybe::new(rows.at(0).expect("size checked"))),
    }
  }
}
